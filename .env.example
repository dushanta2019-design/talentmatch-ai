# ── Core ────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database (PostgreSQL + pgvector) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://resumeai:resumeai@localhost:5432/resumeai

# ── Redis (background jobs via arq) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── S3-compatible file storage (MinIO in dev, S3/R2 in prod) ────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=resume-files
S3_REGION=us-east-1

# ── AI layer ────────────────────────────────────────────────────────
# Claude for extraction, reasoning, explanations (structured JSON)
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-opus-4-8

# Embeddings: "voyage" (production) or "local" (dev/test fallback)
EMBEDDING_PROVIDER=local
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024

# ── Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
